#!/usr/bin/env bash
# claude-multi: wrapper for multi-provider Claude Code sessions.
#
# Routes /v1/messages requests through smart-proxy.py, which dispatches
# each request to the right backend based on the model name. Lets a
# single Claude Code process use models from different providers
# (e.g. main = Anthropic Opus, sonnet slot = Codex gpt-5.4, haiku
# slot = MiniMax-M3).
#
# Required: smart-proxy.py on PATH or in same dir.
set -euo pipefail

SCRIPT_FILE="$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_FILE")" && pwd)"
SMART_PROXY="${SMART_PROXY:-$SCRIPT_DIR/smart-proxy.py}"
CODEX_PROXY="${CODEX_PROXY:-$SCRIPT_DIR/codex-proxy.py}"
GEMINI_PROXY="${GEMINI_PROXY:-$SCRIPT_DIR/gemini-proxy.py}"

SMART_HOST="${CLAUDE_HARNESS_SMART_PROXY_HOST:-127.0.0.1}"
SMART_PORT="${CLAUDE_HARNESS_SMART_PROXY_PORT:-8081}"
CODEX_PORT="${CLAUDE_HARNESS_CODEX_PROXY_PORT:-8080}"
GEMINI_PORT="${CLAUDE_HARNESS_GEMINI_PROXY_PORT:-8082}"
MULTI_VERBOSE="${CLAUDE_HARNESS_MULTI_VERBOSE:-0}"

log() {
  if [ "$MULTI_VERBOSE" = "1" ]; then
    printf "[claude-multi] %s\n" "$*" >&2
  fi
}
die() { printf "[claude-multi] ERROR: %s\n" "$*" >&2; exit 1; }

# Sanity checks
[ -f "$SMART_PROXY" ] || die "smart-proxy.py no encontrado en $SMART_PROXY"
[ -f "$CODEX_PROXY" ] || die "codex-proxy.py no encontrado en $CODEX_PROXY"
command -v python3 >/dev/null || die "python3 no instalado"
command -v claude >/dev/null || die "claude (Claude Code) no instalado"

# Auto-start codex-proxy if any slot needs Codex
need_codex_proxy() {
  local m
  for var in CLAUDE_HARNESS_SLOT_MAIN CLAUDE_HARNESS_SLOT_OPUS CLAUDE_HARNESS_SLOT_SONNET CLAUDE_HARNESS_SLOT_HAIKU; do
    m="${!var:-}"
    case "$m" in
      gpt-*|codex-*|codex/*|o1*|o3*|o4*) return 0 ;;
    esac
  done
  return 1
}

# Auto-start gemini-proxy if any slot routes through Cloud Code Assist
need_gemini_proxy() {
  local m
  for var in CLAUDE_HARNESS_SLOT_MAIN CLAUDE_HARNESS_SLOT_OPUS CLAUDE_HARNESS_SLOT_SONNET CLAUDE_HARNESS_SLOT_HAIKU; do
    m="${!var:-}"
    case "$m" in
      gemini-*|gemini/*|gemini) return 0 ;;
    esac
  done
  return 1
}

# Auto-start smart-proxy
ensure_smart_proxy() {
  if curl -sS --connect-timeout 1 "http://${SMART_HOST}:${SMART_PORT}/health" >/dev/null 2>&1; then
    log "smart-proxy ya corriendo en ${SMART_HOST}:${SMART_PORT}"
    return 0
  fi
  log "Auto-arrancando smart-proxy en ${SMART_HOST}:${SMART_PORT}..."
  nohup python3 "$SMART_PROXY" --host "$SMART_HOST" --port "$SMART_PORT" \
    >"${CLAUDE_HARNESS_SMART_PROXY_LOG:-/tmp/claude-harness-smart-proxy.log}" 2>&1 &
  local pid=$!
  # Wait up to 10s for /health
  local i
  for i in $(seq 1 20); do
    if curl -sS --connect-timeout 1 "http://${SMART_HOST}:${SMART_PORT}/health" >/dev/null 2>&1; then
      log "smart-proxy arrancado (pid=$pid)"
      return 0
    fi
    sleep 0.5
  done
  die "smart-proxy no respondio en ${SMART_HOST}:${SMART_PORT}"
}

# Auto-start codex-proxy if needed
ensure_codex_proxy() {
  if curl -sS --connect-timeout 1 "http://127.0.0.1:${CODEX_PORT}/health" >/dev/null 2>&1; then
    log "codex-proxy ya corriendo en 127.0.0.1:${CODEX_PORT}"
    return 0
  fi
  log "Auto-arrancando codex-proxy en 127.0.0.1:${CODEX_PORT}..."
  nohup python3 "$CODEX_PROXY" --port "$CODEX_PORT" \
    >"${CLAUDE_HARNESS_CODEX_PROXY_LOG:-/tmp/claude-harness-codex-proxy.log}" 2>&1 &
  local pid=$!
  local i
  for i in $(seq 1 20); do
    if curl -sS --connect-timeout 1 "http://127.0.0.1:${CODEX_PORT}/health" >/dev/null 2>&1; then
      log "codex-proxy arrancado (pid=$pid)"
      return 0
    fi
    sleep 0.5
  done
  die "codex-proxy no respondio en 127.0.0.1:${CODEX_PORT}"
}

ensure_codex_proxy_if_needed() {
  if need_codex_proxy; then
    ensure_codex_proxy
  fi
}

# Auto-start gemini-proxy
ensure_gemini_proxy() {
  if curl -sS --connect-timeout 1 "http://127.0.0.1:${GEMINI_PORT}/health" >/dev/null 2>&1; then
    log "gemini-proxy ya corriendo en 127.0.0.1:${GEMINI_PORT}"
    return 0
  fi
  log "Auto-arrancando gemini-proxy en 127.0.0.1:${GEMINI_PORT}..."
  nohup python3 "$GEMINI_PROXY" --port "$GEMINI_PORT" \
    >"${CLAUDE_HARNESS_GEMINI_PROXY_LOG:-/tmp/claude-harness-gemini-proxy.log}" 2>&1 &
  local pid=$!
  local i
  for i in $(seq 1 20); do
    if curl -sS --connect-timeout 1 "http://127.0.0.1:${GEMINI_PORT}/health" >/dev/null 2>&1; then
      log "gemini-proxy arrancado (pid=$pid)"
      return 0
    fi
    sleep 0.5
  done
  die "gemini-proxy no respondio en 127.0.0.1:${GEMINI_PORT}"
}

ensure_gemini_proxy_if_needed() {
  if need_gemini_proxy; then
    ensure_gemini_proxy
  fi
}

# Refresh Codex's OAuth token if it's close to expiring. The standalone
# `claude-codex` wrapper does this on its own when it launches Claude Code
# directly, but when Codex is used through multi-provider (codex slot, or
# codex as main) the request goes through smart-proxy -> codex-proxy and
# nobody refreshes — so after an hour the requests start coming back 401.
#
# Skip the refresh if CLAUDE_HARNESS_CODEX_NO_AUTO_REFRESH=1.
refresh_codex_token_if_needed() {
  local auth_path="${CODEX_AUTH_JSON:-$HOME/.codex/auth.json}"
  [ -f "$auth_path" ] || return 0
  [ "${CLAUDE_HARNESS_CODEX_NO_AUTO_REFRESH:-0}" = "1" ] && return 0

  CODEX_AUTH_JSON="$auth_path" \
  OAUTH_URL="https://auth.openai.com/oauth/token" \
  OAUTH_CLIENT_ID="app_EMoamEEZ73f0CkXaXp7hrann" \
  REFRESH_M="300" \
  python3 - "$auth_path" <<'PY' 2>&1 | while read -r line; do log "codex auth: $line"; done
import sys, json, base64, os, urllib.request, urllib.error, urllib.parse, pathlib
from datetime import datetime, timezone

auth_path = pathlib.Path(sys.argv[1])
try:
    data = json.loads(auth_path.read_text())
except Exception as e:
    print(f"sin auth.json válido ({e}); seguimos")
    sys.exit(0)

t = data.get("tokens") or {}
access_token = t.get("access_token", "")
refresh_token = t.get("refresh_token", "")
if not refresh_token:
    print("sin refresh_token; ejecutá `codex login` para reauth")
    sys.exit(0)

def decode_exp(jwt: str) -> int:
    try:
        payload = jwt.split(".")[1]
        payload += "=" * (-len(payload) % 4)
        return int(json.loads(base64.urlsafe_b64decode(payload)).get("exp", 0))
    except Exception:
        return 0

now = int(datetime.now(timezone.utc).timestamp())
margin = int(os.environ["REFRESH_M"])

# Use the *earliest* of access_token / id_token expirations. The
# access_token JWT often advertises a 7-day exp but the upstream backend
# silently rejects it once the matching id_token (typical 1h) is gone, so
# we have to refresh on that shorter clock too.
access_exp = decode_exp(access_token)
id_exp = decode_exp(t.get("id_token", ""))
exps = [e for e in (access_exp, id_exp) if e > 0]
if not exps:
    print("no se pudo leer exp de ningún token; refrescando por las dudas")
    earliest_exp = 0
else:
    earliest_exp = min(exps)

# Belt-and-suspenders: also refresh if the JSON's last_refresh is older than
# 50 minutes, regardless of what the JWTs claim.
import re
stale_last_refresh = False
last_iso = data.get("last_refresh") or ""
if last_iso:
    try:
        last_dt = datetime.fromisoformat(last_iso.replace("Z", "+00:00"))
        age_s = (datetime.now(timezone.utc) - last_dt).total_seconds()
        stale_last_refresh = age_s > 50 * 60
    except Exception:
        stale_last_refresh = True
else:
    stale_last_refresh = True

if earliest_exp and earliest_exp - now >= margin and not stale_last_refresh:
    print(f"token aún válido ({(earliest_exp - now) // 60} min restantes)")
    sys.exit(0)

print(f"refrescando (earliest_exp={earliest_exp}, now={now}, "
      f"stale_last_refresh={stale_last_refresh})")
body = urllib.parse.urlencode({
    "grant_type": "refresh_token",
    "refresh_token": refresh_token,
    "client_id": os.environ["OAUTH_CLIENT_ID"],
    "scope": "openid profile email offline_access api.connectors.read api.connectors.write api.conversations.write",
}).encode()
req = urllib.request.Request(
    os.environ["OAUTH_URL"], data=body,
    headers={"Content-Type": "application/x-www-form-urlencoded", "Accept": "application/json"},
    method="POST",
)
try:
    with urllib.request.urlopen(req, timeout=30) as resp:
        new = json.loads(resp.read())
except urllib.error.HTTPError as e:
    print(f"refresh falló HTTP {e.code} — ejecutá `codex login`")
    sys.exit(0)
except Exception as e:
    print(f"refresh falló ({e}); seguimos con el token viejo")
    sys.exit(0)

for k in ("access_token", "id_token", "refresh_token"):
    if k not in new:
        print(f"respuesta inválida (falta {k}); no actualizamos")
        sys.exit(0)

data["tokens"]["access_token"] = new["access_token"]
data["tokens"]["id_token"] = new["id_token"]
data["tokens"]["refresh_token"] = new["refresh_token"]
data["last_refresh"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%fZ")
tmp = auth_path.with_suffix(".json.tmp")
tmp.write_text(json.dumps(data, indent=2))
os.chmod(tmp, 0o600)
tmp.replace(auth_path)
print(f"refresh OK; nuevo token válido por ~{decode_exp(new['access_token']) - now}s")
PY
}

# Read auth files to detect which providers are usable
auth_ok() {
  local prov="$1"
  case "$prov" in
    anthropic)
      [ -f "$HOME/.claude/.credentials.json" ] || [ -n "${ANTHROPIC_AUTH_TOKEN:-}" ] || \
        [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ] || return 1
      ;;
    codex) [ -f "$HOME/.codex/auth.json" ] || return 1 ;;
    minimax|openrouter|opencode-go) [ -f "$HOME/.local/share/opencode/auth.json" ] || return 1 ;;
    gateway) [ -f "${CLAUDE_HARNESS_GATEWAY_ROOT:-$HOME/llm-gateway}/.env" ] || [ -n "${LITELLM_MASTER_KEY:-}" ] || return 1 ;;
    gemini) [ -f "$HOME/.gemini/oauth_creds.json" ] || return 1 ;;
    *) return 1 ;;
  esac
  return 0
}

# Detect which providers are needed (main + slots) and warn if any missing
main_model="${CLAUDE_HARNESS_SLOT_MAIN:-}"
[ -z "$main_model" ] && main_model="default"

log "Configuracion multi-provider:"
log "  main     = $main_model"
log "  opus     = ${CLAUDE_HARNESS_SLOT_OPUS:-(= main)}"
log "  sonnet   = ${CLAUDE_HARNESS_SLOT_SONNET:-(= main)}"
log "  haiku    = ${CLAUDE_HARNESS_SLOT_HAIKU:-(= main)}"

# Refresh tokens that go stale (Codex's id_token expires in ~1h). Done before
# auto-starting the proxies so the codex-proxy reads the fresh auth.json on
# first hit instead of caching the expired access_token.
if need_codex_proxy; then
  refresh_codex_token_if_needed
fi

# Auto-start proxies
ensure_smart_proxy
ensure_codex_proxy_if_needed
ensure_gemini_proxy_if_needed

# Configure environment for Claude Code
export ANTHROPIC_BASE_URL="http://${SMART_HOST}:${SMART_PORT}"

if auth_ok anthropic; then
  # User has native Anthropic auth (OAuth or API Token). The smart-proxy will
  # load its own auth from ~/.claude/.credentials.json (or ANTHROPIC_AUTH_TOKEN
  # if set). Clearing both env vars here prevents a stale token in the shell
  # from overriding the proxy's preferred auth source.
  unset ANTHROPIC_API_KEY
  unset ANTHROPIC_AUTH_TOKEN
else
  # User lacks Anthropic auth. Force dummy token so Claude Code doesn't crash
  # on startup. Force the value (no parameter expansion) so a stale env var
  # cannot leak through.
  export ANTHROPIC_AUTH_TOKEN="smart-proxy-passthrough"
  unset ANTHROPIC_API_KEY
fi

# Strip "claude/" prefix so Claude Code sees a clean alias ("opus", "sonnet"…)
# that it can resolve against its live catalog. Hardcoding the resolved snapshot
# in the proxy is brittle — model ids get deprecated, the alias map ships fresh.
strip_claude_prefix() { printf '%s' "${1#claude/}"; }

# Pass the main model
if [ -n "$main_model" ] && [ "$main_model" != "default" ]; then
  export ANTHROPIC_MODEL="$(strip_claude_prefix "$main_model")"
fi

# Set per-slot models (the smart proxy routes these to the right backend)
if [ -n "${CLAUDE_HARNESS_SLOT_OPUS:-}" ]; then
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$(strip_claude_prefix "$CLAUDE_HARNESS_SLOT_OPUS")"
fi
if [ -n "${CLAUDE_HARNESS_SLOT_SONNET:-}" ]; then
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$(strip_claude_prefix "$CLAUDE_HARNESS_SLOT_SONNET")"
fi
if [ -n "${CLAUDE_HARNESS_SLOT_HAIKU:-}" ]; then
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="$(strip_claude_prefix "$CLAUDE_HARNESS_SLOT_HAIKU")"
fi

# Inform smart-proxy which backend to use for unprefixed models.
# Note: MiniMax-* is the MiniMax API (PascalCase), while minimax-* is
# the OpenCode Go default model (lowercase, so the same prefix but
# case-sensitive routing). The smart-proxy uses the same case-sensitive
# heuristic.
if [ -z "${CLAUDE_HARNESS_MAIN_BACKEND:-}" ] && [ -n "$main_model" ] && [ "$main_model" != "default" ]; then
  case "$main_model" in
    claude-*|claude/*|anthropic/*) export CLAUDE_HARNESS_MAIN_BACKEND="anthropic" ;;
    gpt-*|codex-*|codex/*) export CLAUDE_HARNESS_MAIN_BACKEND="codex" ;;
    MiniMax-*|minimax/*) export CLAUDE_HARNESS_MAIN_BACKEND="minimax" ;;
    openrouter/*) export CLAUDE_HARNESS_MAIN_BACKEND="openrouter" ;;
    opencode-go/*|minimax-*) export CLAUDE_HARNESS_MAIN_BACKEND="opencode-go" ;;
    gateway/*) export CLAUDE_HARNESS_MAIN_BACKEND="gateway" ;;
    gemini-*|gemini/*) export CLAUDE_HARNESS_MAIN_BACKEND="gemini" ;;
  esac
fi

# Defense-in-depth: even if the UI set MAIN_BACKEND="claude" (the provider id),
# the proxy only knows "anthropic". Normalize before writing to disk.
if [ "${CLAUDE_HARNESS_MAIN_BACKEND:-}" = "claude" ]; then
  export CLAUDE_HARNESS_MAIN_BACKEND="anthropic"
fi

if [ -n "${CLAUDE_HARNESS_MAIN_BACKEND:-}" ]; then
  echo "$CLAUDE_HARNESS_MAIN_BACKEND" > /tmp/claude-harness-main-backend.txt
fi

# Tell the Codex proxy (if running) the upstream URL
export CLAUDE_HARNESS_CODEX_PROXY_URL="http://127.0.0.1:${CODEX_PORT}"
export CLAUDE_HARNESS_GEMINI_PROXY_URL="http://127.0.0.1:${GEMINI_PORT}"

# Reduce non-essential traffic
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}"
export API_TIMEOUT_MS="${API_TIMEOUT_MS:-3000000}"

log "Lanzando Claude Code con argumentos: $*"
exec claude "$@"
